diff --git a/src/utils/rate-limiter.ts b/src/utils/rate-limiter.ts
new file mode 100644
index 0000000..e5f8a21
--- /dev/null
+++ b/src/utils/rate-limiter.ts
@@ -0,0 +1,68 @@
+interface ClientRecord {
+  attempts: number;
+  firstAttempt: number;   // epoch ms
+  lastAttempt: number;
+  blocked: boolean;
+}
+
+export class RateLimiter {
+  private static instance: RateLimiter;
+  private clients: Map<string, ClientRecord> = new Map();
+
+  private constructor() {}
+
+  static getInstance(): RateLimiter {
+    if (!RateLimiter.instance) {
+      RateLimiter.instance = new RateLimiter();
+    }
+    return RateLimiter.instance;
+  }
+
+  isAllowed(clientId: string, windowSec: number, maxAttempts: number): boolean {
+    const now = Date.now();
+    const record = this.clients.get(clientId);
+
+    if (!record) {
+      this.clients.set(clientId, {
+        attempts: 1,
+        firstAttempt: now,
+        lastAttempt: now,
+        blocked: false,
+      });
+      return true;
+    }
+
+    // Reset window if expired
+    if (now - record.firstAttempt > windowSec * 1000) {
+      record.attempts = 1;
+      record.firstAttempt = now;
+      record.lastAttempt = now;
+      record.blocked = false;
+      return true;
+    }
+
+    record.attempts += 1;
+    record.lastAttempt = now;
+
+    if (record.attempts > maxAttempts) {
+      record.blocked = true;
+      return false;
+    }
+
+    return true;
+  }
+
+  getRetryAfter(clientId: string, windowSec: number): number {
+    const record = this.clients.get(clientId);
+    if (!record) return 0;
+    const elapsed = (Date.now() - record.firstAttempt) / 1000;
+    return Math.max(0, Math.ceil(windowSec - elapsed));
+  }
+
+  recordSuccess(clientId: string): void {
+    const record = this.clients.get(clientId);
+    if (record) {
+      record.attempts = Math.max(0, record.attempts - 1);
+    }
+  }
+}
